{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Battery chemistries",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "nominal", "charge", "storage", "cutoff"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
      "name": { "type": "string", "minLength": 1 },
      "nominal": { "type": "number", "exclusiveMinimum": 0 },
      "charge": { "type": "number", "exclusiveMinimum": 0 },
      "storage": { "type": "number", "exclusiveMinimum": 0 },
      "cutoff": { "type": "number", "exclusiveMinimum": 0 }
    }
  }
}
